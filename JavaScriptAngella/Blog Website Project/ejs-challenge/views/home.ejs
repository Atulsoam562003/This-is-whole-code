<%- include("partials/header.ejs") -%>

<h1>Home</h1>
<p> <%= homeStartingContent %> </p>

<% newPosts.forEach( (element) => {  %>
    <h1> <%= element.title %> </h1> <br>
    <p>
        <%= element.content.substring(0, 100) + "..." %>
        <a href="/posts/ <%= element.title %> ">Read More</a>
    </p>
<% })  %>

<%- include("partials/footer.ejs") -%>