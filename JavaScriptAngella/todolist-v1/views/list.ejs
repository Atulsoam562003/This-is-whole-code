<!-- any thing which is valid HTML is valid for ejs file -->
<%- include("header") -%>

    <div class="box" id="heading">
        <h1> <%= listTitle %> </h1>
    </div>

    <div class="box">
        <!--add these scriplets to every single bit of JS code  and these work on line by line basis -->
        <% for(var i = 0; i < newListItems.length; i++) { %>
            <div class="item">
                <input type="checkbox">
                <p> <%= newListItems[i] %></p>
            </div>
            <% } %>
        <form class="item" action="/" method="post">
            <input type="text" name="newItem" placeholder="New Item" autocomplete="off">
            <button type="submit" name="list" value= <%= listTitle %> >+</button>
        </form>

    </div>

<%- include("footer") -%>